---
import Base from '../layouts/Base.astro';
---
<Base title="Bootslapped" description="Marketing tools and guides for bootstrapped solo founders who figure it out.">

  <style>
    :root {
      --black: #0a0a0a;
      --white: #ffffff;
      --off-white: #f5f4f0;
      --accent: #ff4d00;
      --gray: #6b7280;
      --gray-light: #e5e7eb;
      --max-width: 1200px;
    }

    /* HERO */
    .hero {
      background: var(--black);
      padding: 5rem 2rem 4rem;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 4rem;
      align-items: center;
      max-width: var(--max-width);
      margin: 0 auto;
    }

    .hero-left h1 {
      font-size: clamp(2.2rem, 5vw, 3.5rem);
      font-weight: 800;
      color: var(--white);
      line-height: 1.1;
      letter-spacing: -0.04em;
      margin-bottom: 1.25rem;
    }

    .hero-left h1 em {
      color: var(--accent);
      font-style: normal;
    }

    .hero-left p {
      color: #9ca3af;
      font-size: 1.1rem;
      line-height: 1.65;
      margin-bottom: 2rem;
      max-width: 480px;
    }

    .hero-actions {
      display: flex;
      gap: 1rem;
      flex-wrap: wrap;
    }

    .btn-primary {
      background: var(--accent);
      color: var(--white);
      padding: 0.75rem 1.75rem;
      border-radius: 4px;
      font-weight: 700;
      font-size: 0.95rem;
      display: inline-block;
      transition: background 0.2s;
    }

    .btn-primary:hover { background: #cc3d00; }

    .btn-secondary {
      background: transparent;
      color: #9ca3af;
      padding: 0.75rem 1.75rem;
      border-radius: 4px;
      font-weight: 600;
      font-size: 0.95rem;
      border: 1px solid #2d2d2d;
      display: inline-block;
      transition: all 0.2s;
    }

    .btn-secondary:hover { border-color: #4b5563; color: var(--white); }

    .hero-right {
      background: #111;
      border: 1px solid #1f1f1f;
      border-radius: 8px;
      padding: 2rem;
    }

    .hero-right h3 {
      color: var(--white);
      font-size: 0.8rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      margin-bottom: 1.25rem;
      color: var(--accent);
    }

    .tool-category {
      margin-bottom: 1.25rem;
    }

    .tool-category-label {
      font-size: 0.72rem;
      color: #4b5563;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      margin-bottom: 0.5rem;
    }

    .tool-pills {
      display: flex;
      gap: 0.5rem;
      flex-wrap: wrap;
    }

    .pill {
      background: #1a1a1a;
      border: 1px solid #2d2d2d;
      color: #9ca3af;
      font-size: 0.8rem;
      padding: 0.3rem 0.75rem;
      border-radius: 100px;
      transition: all 0.2s;
    }

    .pill:hover { border-color: var(--accent); color: var(--white); }

    /* TOOLS STRIP */
    .tools-strip {
      background: var(--white);
      border-bottom: 1px solid var(--gray-light);
      padding: 1.5rem 2rem;
    }

    .tools-strip-inner {
      max-width: var(--max-width);
      margin: 0 auto;
      display: flex;
      gap: 2rem;
      align-items: center;
      flex-wrap: wrap;
    }

    .strip-label {
      font-size: 0.72rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: var(--gray);
      white-space: nowrap;
    }

    .strip-categories {
      display: flex;
      gap: 0.75rem;
      flex-wrap: wrap;
    }

    .strip-cat {
      font-size: 0.82rem;
      font-weight: 600;
      color: var(--black);
      padding: 0.35rem 0.9rem;
      border-radius: 100px;
      border: 1px solid var(--gray-light);
      transition: all 0.2s;
    }

    .strip-cat:hover {
      background: var(--black);
      color: var(--white);
      border-color: var(--black);
    }

    /* ARTICLES GRID */
    .articles-section {
      max-width: var(--max-width);
      margin: 4rem auto;
      padding: 0 2rem;
    }

    .section-header {
      display: flex;
      justify-content: space-between;
      align-items: baseline;
      margin-bottom: 2rem;
    }

    .section-header h2 {
      font-size: 1.5rem;
      font-weight: 800;
      letter-spacing: -0.03em;
    }

    .section-header a {
      font-size: 0.85rem;
      color: var(--accent);
      font-weight: 600;
    }

    .articles-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1.5rem;
    }

    .article-card {
      background: var(--white);
      border: 1px solid var(--gray-light);
      border-radius: 8px;
      padding: 1.5rem;
      transition: all 0.2s;
    }

    .article-card:hover {
      border-color: var(--black);
      transform: translateY(-2px);
    }

    .card-tag {
      font-size: 0.7rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: var(--accent);
      margin-bottom: 0.75rem;
    }

    .article-card h3 {
      font-size: 1rem;
      font-weight: 700;
      line-height: 1.35;
      margin-bottom: 0.6rem;
      letter-spacing: -0.02em;
    }

    .article-card p {
      font-size: 0.85rem;
      color: var(--gray);
      line-height: 1.6;
    }

    /* DIAGNOSTIC CTA */
    .diagnostic-cta {
      background: var(--accent);
      padding: 4rem 2rem;
      text-align: center;
    }

    .diagnostic-cta h2 {
      font-size: clamp(1.8rem, 4vw, 2.8rem);
      font-weight: 800;
      color: var(--white);
      letter-spacing: -0.04em;
      margin-bottom: 1rem;
    }

    .diagnostic-cta p {
      color: rgba(255,255,255,0.8);
      font-size: 1.05rem;
      margin-bottom: 2rem;
      max-width: 520px;
      margin-left: auto;
      margin-right: auto;
    }

    .btn-white {
      background: var(--white);
      color: var(--accent);
      padding: 0.85rem 2rem;
      border-radius: 4px;
      font-weight: 800;
      font-size: 1rem;
      display: inline-block;
      transition: all 0.2s;
    }

    .btn-white:hover { background: var(--off-white); }

    @media (max-width: 768px) {
      .hero { grid-template-columns: 1fr; gap: 2rem; }
      .articles-grid { grid-template-columns: 1fr; }
      .hero-right { display: none; }
    }
  </style>

  <!-- HERO -->
  <section style="background: #0a0a0a;">
    <div class="hero">
      <div class="hero-left">
        <h1>Marketing for founders who <em>figure it out.</em></h1>
        <p>No agency. No budget. No BS. Bootslapped cuts through the noise with tool comparisons, decision guides, and frameworks built for bootstrapped operators.</p>
        <div class="hero-actions">
          <a href="/diagnostic" class="btn-primary">Take the Free Diagnostic →</a>
          <a href="/tools" class="btn-secondary">Browse Tools</a>
        </div>
      </div>
      <div class="hero-right">
        <h3>Find the right tool for the job</h3>
        <div class="tool-category">
          <div class="tool-category-label">Email Marketing</div>
          <div class="tool-pills">
            <a href="/compare/mailchimp-vs-klaviyo" class="pill">Mailchimp vs Klaviyo</a>
            <a href="/compare/convertkit-vs-beehiiv" class="pill">ConvertKit vs Beehiiv</a>
          </div>
        </div>
        <div class="tool-category">
          <div class="tool-category-label">Landing Pages</div>
          <div class="tool-pills">
            <a href="/compare/carrd-vs-webflow" class="pill">Carrd vs Webflow</a>
            <a href="/compare/unbounce-vs-leadpages" class="pill">Unbounce vs Leadpages</a>
          </div>
        </div>
        <div class="tool-category">
          <div class="tool-category-label">Analytics</div>
          <div class="tool-pills">
            <a href="/compare/ga4-vs-plausible" class="pill">GA4 vs Plausible</a>
            <a href="/compare/hotjar-vs-microsoft-clarity" class="pill">Hotjar vs Clarity</a>
          </div>
        </div>
        <div class="tool-category">
          <div class="tool-category-label">Automation</div>
          <div class="tool-pills">
            <a href="/compare/zapier-vs-make" class="pill">Zapier vs Make</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- TOOLS STRIP -->
  <div class="tools-strip">
    <div class="tools-strip-inner">
      <span class="strip-label">Browse by category</span>
      <div class="strip-categories">
        <a href="/tools/email" class="strip-cat">Email Marketing</a>
        <a href="/tools/landing-pages" class="strip-cat">Landing Pages</a>
        <a href="/tools/analytics" class="strip-cat">Analytics</a>
        <a href="/tools/automation" class="strip-cat">Automation</a>
        <a href="/tools/crm" class="strip-cat">CRM</a>
        <a href="/tools/seo" class="strip-cat">SEO</a>
        <a href="/tools/social" class="strip-cat">Social</a>
      </div>
    </div>
  </div>

  <!-- ARTICLES GRID -->
  <section class="articles-section">
    <div class="section-header">
      <h2>Latest guides</h2>
      <a href="/guides">View all →</a>
    </div>
    <div class="articles-grid">
      <a href="/compare/mailchimp-vs-klaviyo" class="article-card">
        <div class="card-tag">Comparison</div>
        <h3>Mailchimp vs Klaviyo: Which One Actually Makes Sense for Solo Founders?</h3>
        <p>A no-fluff breakdown of cost, features, and when each tool earns its keep.</p>
      </a>
      <a href="/guides/email-list-from-zero" class="article-card">
        <div class="card-tag">Guide</div>
        <h3>How to Build an Email List from Zero Without Paying for Ads</h3>
        <p>The exact playbook for getting your first 500 subscribers on a bootstrapper budget.</p>
      </a>
      <a href="/compare/zapier-vs-make" class="article-card">
        <div class="card-tag">Comparison</div>
        <h3>Zapier vs Make: The Honest Breakdown for Founders Who Hate Overpaying</h3>
        <p>Task limits, pricing traps, and which one wins for lean operators.</p>
      </a>
    </div>
  </section>

  <!-- DIAGNOSTIC CTA -->
  <section class="diagnostic-cta">
    <h2>Not sure where your marketing is leaking?</h2>
    <p>Take the free Bootslapped diagnostic. 5 minutes. No email required to start. Get a clear picture of what to fix first.</p>
    <a href="/diagnostic" class="btn-white">Take the Diagnostic — It's Free</a>
  </section>

</Base>
