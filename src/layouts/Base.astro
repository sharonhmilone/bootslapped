---
const { title = 'Bootslapped', description = 'For founders who figure it out.' } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title} | Bootslapped</title>
  <link rel="sitemap" href="/sitemap-index.xml" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --black: #0a0a0a;
      --white: #ffffff;
      --off-white: #f5f4f0;
      --accent: #ff4d00;
      --accent-dark: #cc3d00;
      --gray: #6b7280;
      --gray-light: #e5e7eb;
      --font: 'Inter', sans-serif;
      --max-width: 1200px;
    }

    body {
      font-family: var(--font);
      background: var(--off-white);
      color: var(--black);
      line-height: 1.6;
    }

    a { color: inherit; text-decoration: none; }
    img { max-width: 100%; display: block; }

    /* NAV */
    nav {
      background: var(--black);
      padding: 0 2rem;
      display: flex;
      align-items: center;
      justify-content: space-between;
      height: 60px;
      position: sticky;
      top: 0;
      z-index: 100;
    }

    .nav-logo {
      font-size: 1.2rem;
      font-weight: 800;
      color: var(--white);
      letter-spacing: -0.03em;
    }

    .nav-logo span { color: var(--accent); }

    .nav-links {
      display: flex;
      gap: 2rem;
      list-style: none;
    }

    .nav-links a {
      color: var(--gray);
      font-size: 0.875rem;
      font-weight: 500;
      transition: color 0.2s;
    }

    .nav-links a:hover { color: var(--white); }

    .nav-cta {
      background: var(--accent);
      color: var(--white) !important;
      padding: 0.4rem 1rem;
      border-radius: 4px;
      font-weight: 600 !important;
    }

    .nav-cta:hover { background: var(--accent-dark); color: var(--white) !important; }

    /* FOOTER */
    footer {
      background: var(--black);
      color: var(--gray);
      padding: 3rem 2rem;
      margin-top: 6rem;
    }

    .footer-inner {
      max-width: var(--max-width);
      margin: 0 auto;
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      gap: 2rem;
      flex-wrap: wrap;
    }

    .footer-brand {
      font-size: 1.1rem;
      font-weight: 800;
      color: var(--white);
      letter-spacing: -0.03em;
      margin-bottom: 0.5rem;
    }

    .footer-brand span { color: var(--accent); }

    .footer-tagline {
      font-size: 0.8rem;
      color: var(--gray);
    }

    .footer-links {
      display: flex;
      gap: 3rem;
      flex-wrap: wrap;
    }

    .footer-col h4 {
      color: var(--white);
      font-size: 0.75rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      margin-bottom: 0.75rem;
    }

    .footer-col ul { list-style: none; }
    .footer-col li { margin-bottom: 0.4rem; }
    .footer-col a { font-size: 0.85rem; color: var(--gray); transition: color 0.2s; }
    .footer-col a:hover { color: var(--white); }

    .footer-bottom {
      max-width: var(--max-width);
      margin: 2rem auto 0;
      padding-top: 1.5rem;
      border-top: 1px solid #1f1f1f;
      font-size: 0.75rem;
      display: flex;
      justify-content: space-between;
      flex-wrap: wrap;
      gap: 0.5rem;
    }

    .affiliate-disclosure {
      font-size: 0.72rem;
      color: #4b5563;
      max-width: 600px;
      line-height: 1.5;
    }
  </style>
</head>
<body>

  <nav>
    <a href="/" class="nav-logo">Boot<span>slapped</span></a>
    <ul class="nav-links">
      <li><a href="/tools">Tools</a></li>
      <li><a href="/guides">Guides</a></li>
      <li><a href="/compare">Compare</a></li>
      <li><a href="/diagnostic" class="nav-cta">Free Diagnostic</a></li>
    </ul>
  </nav>

  <main>
    <slot />
  </main>

  <footer>
    <div class="footer-inner">
      <div>
        <div class="footer-brand">Boot<span>slapped</span></div>
        <div class="footer-tagline">For founders who figure it out.</div>
      </div>
      <div class="footer-links">
        <div class="footer-col">
          <h4>Tools</h4>
          <ul>
            <li><a href="/tools/email">Email Marketing</a></li>
            <li><a href="/tools/landing-pages">Landing Pages</a></li>
            <li><a href="/tools/analytics">Analytics</a></li>
            <li><a href="/tools/automation">Automation</a></li>
          </ul>
        </div>
        <div class="footer-col">
          <h4>Guides</h4>
          <ul>
            <li><a href="/guides">All Guides</a></li>
            <li><a href="/compare">Comparisons</a></li>
            <li><a href="/diagnostic">Diagnostic</a></li>
          </ul>
        </div>
        <div class="footer-col">
          <h4>Site</h4>
          <ul>
            <li><a href="/about">About</a></li>
            <li><a href="/newsletter">Newsletter</a></li>
            <li><a href="/contact">Contact</a></li>
          </ul>
        </div>
      </div>
    </div>
    <div class="footer-bottom">
      <span>© {new Date().getFullYear()} Bootslapped. All rights reserved.</span>
      <span class="affiliate-disclosure">Some links on this site are affiliate links. We may earn a commission if you purchase through them — at no extra cost to you. We only recommend tools we'd actually use.</span>
    </div>
  </footer>

</body>
</html>
